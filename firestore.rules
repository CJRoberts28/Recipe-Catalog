rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isWhitelisted() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.active == true;
    }

    // Recipe catalog — full access for both users
    match /recipes/{recipeId} {
      allow read, write: if isWhitelisted();
    }

    // Shared notification schedule config
    match /settings/notifications {
      allow read, write: if isWhitelisted();
    }

    // FCM tokens — each user can only manage their own token
    match /fcm_tokens/{uid} {
      allow read, write, delete: if isWhitelisted() && request.auth.uid == uid;
    }

    // Pantry — shared between both users
    match /pantry/{docId} {
      allow read, write: if isWhitelisted();
    }

    // Access control — managed manually in Firebase Console
    match /allowedUsers/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }
  }
}
